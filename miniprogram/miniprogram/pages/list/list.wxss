.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.search-bar {
  margin: 24rpx 30rpx;
  padding: 16rpx 24rpx;
  background: #ffffff;
  border-radius: 12rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.ph {
  color: #888888;
}

.search-btn {
  font-size: 28rpx;
  color: #8b5a2b;
  padding-left: 24rpx;
}

.filter-block {
  padding: 0 30rpx 10rpx;
}

.filter-label {
  display: block;
  font-size: 24rpx;
  color: #888888;
  margin-bottom: 12rpx;
}

.chips {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  margin-bottom: 24rpx;
}

.list-wrap {
  padding: 0 30rpx;
}

.more,
.end {
  text-align: center;
  font-size: 24rpx;
  color: #888888;
  padding: 24rpx 0;
}
