.page-scroll {
  height: 100vh;
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.search-bar {
  margin: 24rpx 30rpx;
  padding: 16rpx 24rpx 20rpx;
  background: #ffffff;
  border-radius: 12rpx;
}

.search-inner {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.suggest-box {
  margin-top: 12rpx;
  border-top: 1rpx solid #eee8dc;
  padding-top: 8rpx;
  max-height: 280rpx;
  overflow-y: auto;
}

.suggest-item {
  font-size: 28rpx;
  color: #555555;
  padding: 14rpx 8rpx;
  border-bottom: 1rpx solid #f5f0e6;
}

.history-row {
  margin-top: 12rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.history-label {
  font-size: 22rpx;
  color: #999999;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.history-scroll {
  flex: 1;
  white-space: nowrap;
}

.history-chip {
  display: inline-block;
  font-size: 24rpx;
  color: #8b5a2b;
  padding: 8rpx 20rpx;
  margin-right: 12rpx;
  background: #fff8ec;
  border-radius: 999rpx;
  border: 1rpx solid #e8dcc8;
}

.no-hit {
  margin-bottom: 24rpx;
  padding: 24rpx;
  background: #fffaf5;
  border-radius: 12rpx;
}

.no-hit-title {
  display: block;
  font-size: 30rpx;
  color: #333333;
  margin-bottom: 8rpx;
}

.no-hit-sub {
  display: block;
  font-size: 24rpx;
  color: #888888;
  margin-bottom: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.ph {
  color: #888888;
}

.search-btn {
  font-size: 28rpx;
  color: #8b5a2b;
  padding-left: 24rpx;
}

.filter-block {
  padding: 0 30rpx 10rpx;
}

.filter-label {
  display: block;
  font-size: 24rpx;
  color: #888888;
  margin-bottom: 12rpx;
}

.chips {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  margin-bottom: 24rpx;
}

.list-wrap {
  padding: 0 30rpx;
}

.more,
.end {
  text-align: center;
  font-size: 24rpx;
  color: #888888;
  padding: 24rpx 0;
}

.preset-block {
  margin: 0 30rpx 20rpx;
  padding: 20rpx 24rpx 24rpx;
  background: #ffffff;
  border-radius: 12rpx;
}

.preset-scroll {
  white-space: nowrap;
  width: 100%;
}

.preset-scroll-inner {
  display: inline-flex;
  flex-direction: row;
  gap: 12rpx;
  padding-bottom: 8rpx;
}

.preset-chip {
  margin: 0;
  font-size: 24rpx;
  color: #555555;
  background: #f5f0e6;
  border: 1rpx solid #e8dcc8;
  border-radius: 10rpx;
  padding: 0 20rpx;
  line-height: 56rpx;
  min-height: 56rpx;
}

.preset-chip.active {
  color: #8b5a2b;
  border-color: #d2b48c;
  background: #fff8ec;
  font-weight: 500;
}

.chips-wrap {
  flex-wrap: wrap;
}

.list-footer {
  font-size: 22rpx;
  color: #999999;
  line-height: 1.5;
  padding: 8rpx 40rpx 24rpx;
  text-align: center;
}

.list-oa {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: #8b5a2b;
  padding: 8rpx 0 0;
  text-decoration: underline;
}

.spacer {
  height: 24rpx;
}
