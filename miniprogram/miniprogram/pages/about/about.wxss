.page {
  min-height: 100vh;
  padding: 30rpx;
  box-sizing: border-box;
}

.block {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 30rpx;
}

.h1 {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #8b5a2b;
  margin-bottom: 24rpx;
}

.h2 {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 20rpx;
}

.p {
  display: block;
  font-size: 28rpx;
  color: #555555;
  line-height: 1.65;
  margin-bottom: 16rpx;
}

.p.small {
  font-size: 24rpx;
  color: #777777;
}

.quote {
  color: #6b5344;
  font-weight: 500;
}

.heart {
  margin-top: 8rpx;
  color: #5c4a3a;
}

.email-block {
  border: 2rpx solid #d2b48c;
  background: #fffaf0;
}

.email {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #8b5a2b;
  margin-bottom: 12rpx;
  word-break: break-all;
}

.rule-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.rule-num {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  font-size: 24rpx;
  color: #ffffff;
  background: #8b5a2b;
  border-radius: 8rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.rule-t {
  flex: 1;
  font-size: 28rpx;
  color: #555555;
  line-height: 1.65;
}

.log-h {
  display: block;
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin: 8rpx 0 12rpx;
}

.log-line {
  display: block;
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
  margin-bottom: 10rpx;
}

.footer-fixed {
  margin: 0 0 20rpx;
  padding: 20rpx 24rpx;
  font-size: 24rpx;
  color: #888888;
  line-height: 1.55;
  text-align: center;
}

.qr-block {
  text-align: center;
}

.qr-row {
  display: flex;
  flex-direction: row;
  justify-content: center;
  gap: 40rpx;
  margin: 24rpx 0;
}

.qr-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.qr-img {
  width: 220rpx;
  height: 220rpx;
  background: #fffaf0;
  border-radius: 12rpx;
  border: 1rpx solid #e8dcc8;
}

.qr-cap {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #555555;
}

.btn-open-oa {
  margin: 8rpx auto 20rpx;
  width: 90%;
  min-height: 88rpx;
  line-height: 88rpx;
  background: #8b5a2b !important;
  color: #ffffff !important;
  border-radius: 12rpx !important;
  font-size: 28rpx;
}

.btn-open-oa::after {
  border: none;
}

.oa-plugin-wrap {
  min-height: 120rpx;
  margin: 16rpx 0;
}

.oa-tip {
  text-align: left;
}

.bottom-space {
  height: 48rpx;
}
