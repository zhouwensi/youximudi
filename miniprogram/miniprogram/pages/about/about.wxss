.page {
  min-height: 100vh;
  padding: 30rpx;
  box-sizing: border-box;
}

.block {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 30rpx;
}

.h1 {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #8b5a2b;
  margin-bottom: 24rpx;
}

.h2 {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 20rpx;
}

.p {
  display: block;
  font-size: 28rpx;
  color: #555555;
  line-height: 1.65;
  margin-bottom: 16rpx;
}

.bottom-space {
  height: 48rpx;
}
