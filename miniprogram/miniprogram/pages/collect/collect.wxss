.page-scroll {
  height: 100vh;
  box-sizing: border-box;
}

.stats {
  margin: 24rpx 30rpx;
  padding: 28rpx 24rpx;
  background: #ffffff;
  border-radius: 12rpx;
}

.stats-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

.stats-body {
  display: block;
  font-size: 26rpx;
  color: #555555;
  line-height: 1.65;
}

.stats-gold {
  border: 2rpx solid #d2b48c;
  background: linear-gradient(165deg, #fffef9 0%, #fff5e0 100%);
}

.stats-extra {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #6b5344;
  line-height: 1.6;
}

.poster-actions {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.poster-btn {
  width: 100%;
  min-height: 88rpx;
  line-height: 88rpx;
  margin: 0;
}

.poster-canvas-hidden {
  position: fixed;
  left: -9999px;
  top: 0;
  width: 375px;
  height: 640px;
}

.filter-empty {
  margin: 0 30rpx 24rpx;
  padding: 24rpx;
  background: #fffaf0;
  border-radius: 12rpx;
  border: 1rpx dashed #d2b48c;
}

.filter-empty-t {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.55;
}

.filter-block {
  margin: 0 30rpx 20rpx;
  padding: 20rpx 24rpx 8rpx;
  background: #ffffff;
  border-radius: 12rpx;
}

.sort-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.btn-sort {
  margin: 0;
  min-height: 64rpx;
  line-height: 64rpx;
  padding: 0 24rpx;
  font-size: 24rpx;
  color: #8b5a2b;
  background: #fff8ec;
  border: 1rpx solid #d2b48c;
  border-radius: 10rpx;
}

.filter-label {
  display: block;
  font-size: 24rpx;
  color: #888888;
  margin-bottom: 12rpx;
}

.chips {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}

.chips-wrap {
  flex-wrap: wrap;
}

.list-wrap {
  padding: 0 30rpx 20rpx;
}

.empty-wrap {
  padding: 20rpx 30rpx 40rpx;
}

.empty-msg {
  display: block;
  text-align: center;
  font-size: 30rpx;
  color: #555555;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.empty-sub {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 24rpx;
}

.rec-list {
  margin-bottom: 32rpx;
}

.empty-btn {
  width: 100%;
  min-height: 96rpx;
  line-height: 96rpx;
}

.page-footer {
  font-size: 22rpx;
  color: #999999;
  line-height: 1.5;
  padding: 8rpx 40rpx 24rpx;
  text-align: center;
}

.spacer {
  height: 24rpx;
}
