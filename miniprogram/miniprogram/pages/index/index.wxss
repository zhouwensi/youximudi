.page {
  height: 100vh;
  box-sizing: border-box;
}

.pixel-bar {
  text-align: center;
  font-size: 22rpx;
  letter-spacing: 8rpx;
  color: #c4a574;
  padding: 16rpx 0 0;
  opacity: 0.85;
}

.hero {
  padding: 24rpx 30rpx 20rpx;
}

.hero-inner {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  border: 1rpx solid rgba(139, 90, 43, 0.12);
}

.hero-title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #8b5a2b;
  margin-bottom: 20rpx;
}

.hero-sub {
  display: block;
  font-size: 26rpx;
  color: #555555;
  line-height: 1.65;
}

.section {
  padding: 0 30rpx 40rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 24rpx;
}

.row2 {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
}

.entry {
  flex: 1;
  background: #ffffff;
  border-radius: 12rpx;
  padding: 28rpx 20rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(139, 90, 43, 0.1);
  min-height: 160rpx;
}

.entry-icon {
  display: block;
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.entry-title {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #8b5a2b;
  margin-bottom: 8rpx;
}

.entry-desc {
  display: block;
  font-size: 24rpx;
  color: #888888;
}

.random-wrap {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(139, 90, 43, 0.08);
}

.random-btns {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  margin-top: 24rpx;
}

.random-btns button {
  flex: 1;
  min-height: 88rpx;
  line-height: 88rpx;
}

.oa-foot {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: #8b5a2b;
  padding: 0 40rpx 16rpx;
  text-decoration: underline;
}

.footer-note {
  padding: 0 40rpx 60rpx;
  font-size: 22rpx;
  color: #888888;
  text-align: center;
  line-height: 1.55;
}

.spacer {
  height: 24rpx;
}

.today-block {
  margin-top: 8rpx;
}

.today-swiper {
  height: 200rpx;
}

.today-card {
  padding: 24rpx 28rpx;
  background: #fff8f0;
  border-radius: 12rpx;
  border: 1rpx solid #e8dcc8;
  height: 100%;
  box-sizing: border-box;
}

.today-line {
  display: block;
  font-size: 26rpx;
  color: #444444;
  line-height: 1.55;
}

.today-go {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #8b5a2b;
}

.muted-today .today-empty {
  font-size: 26rpx;
  color: #888888;
  line-height: 1.55;
}

.entry-count {
  display: block;
  font-size: 24rpx;
  color: #c45c26;
  margin-bottom: 6rpx;
}

.petition-entry {
  padding: 28rpx 24rpx;
}

.pe-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #5c4033;
  margin-bottom: 8rpx;
}

.pe-sub {
  display: block;
  font-size: 24rpx;
  color: #777777;
  margin-bottom: 12rpx;
}

.pe-go {
  font-size: 26rpx;
  color: #8b5a2b;
}

.time-machine {
  padding: 24rpx;
  background: #ffffff;
  border-radius: 12rpx;
  margin: 0 30rpx 32rpx;
  border: 1rpx solid rgba(139, 90, 43, 0.1);
}

.tm-sub {
  display: block;
  font-size: 24rpx;
  color: #888888;
  margin-bottom: 16rpx;
}

.tm-scroll {
  white-space: nowrap;
  width: 100%;
}

.tm-chip {
  display: inline-block;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
  font-size: 24rpx;
  color: #5c4033;
  background: #fff5e6;
  border: 1rpx solid #d2b48c;
  border-radius: 999rpx;
  padding: 0 24rpx;
  line-height: 64rpx;
  min-height: 64rpx;
}

.welfare {
  margin: 0 30rpx 32rpx;
  padding: 28rpx 24rpx;
}

.welfare-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #8b4513;
  margin-bottom: 8rpx;
}

.welfare-desc {
  display: block;
  font-size: 24rpx;
  color: #666666;
  line-height: 1.55;
  margin-bottom: 12rpx;
}

.welfare-btn {
  font-size: 26rpx;
  color: #8b5a2b;
}

.heat-line {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #999999;
  text-align: center;
}
