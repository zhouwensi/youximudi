.page {
  height: 100vh;
  box-sizing: border-box;
}

.hero {
  padding: 40rpx 30rpx 20rpx;
}

.hero-inner {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 48rpx 32rpx;
  text-align: center;
}

.hero-title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #8b5a2b;
  margin-bottom: 20rpx;
}

.hero-sub {
  display: block;
  font-size: 26rpx;
  color: #555555;
  line-height: 1.6;
}

.section {
  padding: 0 30rpx 40rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 24rpx;
}

.row2 {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
}

.entry {
  flex: 1;
  background: #ffffff;
  border-radius: 12rpx;
  padding: 28rpx 20rpx;
  box-sizing: border-box;
}

.entry-title {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #8b5a2b;
  margin-bottom: 8rpx;
}

.entry-desc {
  display: block;
  font-size: 24rpx;
  color: #888888;
}

.random-wrap {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
}

.random-wrap game-card .card {
  margin-bottom: 0;
}

.random-btns {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  margin-top: 24rpx;
}

.random-btns button {
  flex: 1;
}

.footer-note {
  padding: 0 40rpx 60rpx;
  font-size: 22rpx;
  color: #888888;
  text-align: center;
  line-height: 1.5;
}

.spacer {
  height: 24rpx;
}
