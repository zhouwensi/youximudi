.page {
  min-height: 100vh;
  padding-bottom: 160rpx;
}

.cover-wrap {
  position: relative;
  width: 100%;
}

.cover {
  width: 100%;
  height: 360rpx;
  background: #f5f0e6;
  display: block;
}

.star-fab {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  color: #8b5a2b;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 12rpx;
  border: 1rpx solid #d2b48c;
}

.card {
  background: #ffffff;
  border-radius: 12rpx;
  margin: -40rpx 30rpx 30rpx;
  padding: 32rpx 28rpx;
  position: relative;
}

.base .name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

.row {
  display: flex;
  flex-direction: row;
  margin-bottom: 12rpx;
  font-size: 28rpx;
}

.k {
  width: 180rpx;
  color: #888888;
  flex-shrink: 0;
}

.v {
  flex: 1;
  color: #555555;
}

.tag-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  margin-top: 16rpx;
  gap: 12rpx;
}

.d-tag {
  font-size: 24rpx;
  color: #8b5a2b;
  border: 1rpx solid #d2b48c;
  border-radius: 8rpx;
  padding: 6rpx 16rpx;
}

.section {
  margin: 0 30rpx 30rpx;
  padding: 28rpx;
  background: #ffffff;
  border-radius: 12rpx;
}

.h2 {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 20rpx;
}

.body-text {
  display: block;
  font-size: 28rpx;
  color: #555555;
  line-height: 1.6;
  white-space: pre-wrap;
}

.shots {
  white-space: nowrap;
  width: 100%;
}

.shot {
  width: 280rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 16rpx;
  display: inline-block;
  vertical-align: top;
  background: #f5f0e6;
}

.view-line {
  text-align: center;
  font-size: 24rpx;
  color: #888888;
  padding: 20rpx 30rpx 0;
}

.bottom-pad {
  height: 40rpx;
}

.bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(245, 240, 230, 0.96);
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.bar-btn {
  width: 100%;
}
