.page {
  min-height: 100vh;
  padding-bottom: 220rpx;
}

.hero-swiper-wrap {
  position: relative;
  width: 100%;
}

.hero-swiper {
  width: 100%;
  height: 360rpx;
  background: #f5f0e6;
}

.hero-slide {
  width: 100%;
  height: 360rpx;
  display: block;
}

.star-fab {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  min-width: 96rpx;
  min-height: 96rpx;
  padding: 16rpx 28rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #8b5a2b;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 12rpx;
  border: 1rpx solid #d2b48c;
}

.card {
  background: #ffffff;
  border-radius: 12rpx;
  margin: 0 30rpx 30rpx;
  padding: 32rpx 28rpx;
  position: relative;
  border: 1rpx solid #ece3d6;
}

.hero-stats {
  margin: 24rpx 30rpx 24rpx;
  text-align: center;
}

.stop-big {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #8b4513;
  margin-bottom: 12rpx;
}

.op-big {
  display: block;
  font-size: 28rpx;
  color: #555555;
  margin-bottom: 8rpx;
}

.anniv-hint {
  display: block;
  font-size: 24rpx;
  color: #c45c26;
  margin-top: 8rpx;
}

.base .name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

.subline {
  display: block;
  font-size: 26rpx;
  color: #8b5a2b;
  margin-bottom: 8rpx;
}

.hint {
  display: block;
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #aaaaaa;
  line-height: 1.5;
}

.muted {
  color: #666666;
}

.url-line {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #444444;
  line-height: 1.5;
  word-break: break-all;
}

.h3 {
  display: block;
  font-size: 28rpx;
  color: #444444;
  margin: 20rpx 0 12rpx;
}

.shots-block {
  margin-top: 8rpx;
}

.row {
  display: flex;
  flex-direction: row;
  margin-bottom: 12rpx;
  font-size: 28rpx;
}

.k {
  width: 180rpx;
  color: #888888;
  flex-shrink: 0;
}

.v {
  flex: 1;
  color: #555555;
}

.tag-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  margin-top: 16rpx;
  gap: 12rpx;
}

.d-tag {
  font-size: 24rpx;
  color: #8b5a2b;
  border: 1rpx solid #d2b48c;
  border-radius: 8rpx;
  padding: 6rpx 16rpx;
}

.section {
  margin: 0 30rpx 30rpx;
  padding: 28rpx;
  background: #ffffff;
  border-radius: 12rpx;
}

.h2 {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 20rpx;
}

.body-text {
  display: block;
  font-size: 28rpx;
  color: #555555;
  line-height: 1.6;
  white-space: pre-wrap;
}

.body-text.small {
  font-size: 24rpx;
  color: #888888;
  margin-bottom: 12rpx;
}

.divider {
  height: 1rpx;
  background: linear-gradient(90deg, #d2b48c, transparent);
  margin: 12rpx 0 20rpx;
}

.compare-grid {
  display: flex;
  flex-direction: row;
  margin-top: 16rpx;
  gap: 16rpx;
}

.compare-col {
  flex: 1;
  min-width: 0;
  padding: 16rpx;
  background: #fffaf5;
  border-radius: 12rpx;
  border: 1rpx solid #e8dcc8;
}

.compare-h {
  display: block;
  font-size: 24rpx;
  font-weight: 500;
  color: #8b5a2b;
  margin-bottom: 12rpx;
}

.memory-line {
  display: block;
  font-size: 26rpx;
  color: #555555;
  line-height: 1.65;
  margin-bottom: 12rpx;
}

.interact .flower-count {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin: 16rpx 0 20rpx;
}

.btn-wide {
  width: 100%;
  min-height: 96rpx;
  line-height: 96rpx;
  margin-top: 8rpx;
}

.btn-row {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-top: 16rpx;
}

.btn-half {
  flex: 1;
  min-height: 88rpx;
  line-height: 88rpx;
  margin: 0;
}

.capsule-area {
  width: 100%;
  min-height: 200rpx;
  margin-top: 12rpx;
  padding: 16rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  background: #fffaf5;
  border: 1rpx solid #e8dcc8;
  border-radius: 12rpx;
}

.nick-input {
  margin-top: 12rpx;
  padding: 16rpx 20rpx;
  border: 1rpx solid #e8dcc8;
  border-radius: 12rpx;
  background: #fffaf5;
  font-size: 28rpx;
}

.shots {
  white-space: nowrap;
  width: 100%;
}

.shot {
  width: 280rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 16rpx;
  display: inline-block;
  vertical-align: top;
  background: #f5f0e6;
}

.compliance {
  margin: 0 30rpx 30rpx;
  padding: 24rpx;
  background: #fffaf0;
  border-radius: 12rpx;
  border: 1rpx solid #e8dcc8;
}

.compliance-text {
  display: block;
  font-size: 24rpx;
  color: #555555;
  line-height: 1.65;
}

.compliance-text.small {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #888888;
}

.empty-tip {
  padding: 80rpx 40rpx;
  text-align: center;
  font-size: 28rpx;
  color: #888888;
}

.bottom-pad {
  height: 40rpx;
}

.bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(245, 240, 230, 0.96);
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.bar-col {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.bar-btn {
  width: 100%;
  min-height: 96rpx;
  line-height: 96rpx;
  margin: 0;
}

.poster-canvas-hidden {
  position: fixed;
  left: -9999px;
  top: 0;
  width: 375px;
  height: 640px;
}

.modal-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.modal-box {
  width: 100%;
  max-width: 600rpx;
  background: #fffaf0;
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
  border: 2rpx solid #d2b48c;
}

.modal-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #8b4513;
  margin-bottom: 20rpx;
  text-align: center;
}

.modal-body {
  display: block;
  font-size: 28rpx;
  color: #555555;
  line-height: 1.65;
  margin-bottom: 28rpx;
}

.modal-btn,
.modal-btn2 {
  width: 100%;
  min-height: 88rpx;
  line-height: 88rpx;
  margin: 0 0 12rpx;
}
