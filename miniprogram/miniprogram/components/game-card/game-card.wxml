<view class="card card-shadow">
  <view wx:if="{{game._badge}}" class="badge-anniv">{{game._badge}}</view>
  <view class="card-main" bindtap="onCardTap">
    <image
      class="cover"
      src="{{coverSrc}}"
      mode="aspectFill"
      lazy-load
    />
    <view class="body">
      <text class="title">{{game.game_name}}</text>
      <text class="time">{{game.release_time}} · {{game.stop_time}}</text>
      <text class="submeta" wx:if="{{game._submeta}}">{{game._submeta}}</text>
      <view class="stat-row" wx:if="{{game._showStats}}">
        <text class="stat-item">🌸{{game._flowersMine || 0}}</text>
        <text class="stat-item">✨{{game._petitionCrowd}}</text>
        <text class="stat-item">🕯{{game._flowerCrowd}}</text>
      </view>
      <view class="tags" wx:if="{{game.game_tags && game.game_tags.length}}">
        <text class="tag" wx:for="{{game.game_tags}}" wx:key="*this">{{item}}</text>
      </view>
      <text class="intro" wx:if="{{game.one_line}}">{{game.one_line}}</text>
      <text class="intro" wx:elif="{{shortIntro}}">{{shortIntro}}</text>
    </view>
  </view>
  <view wx:if="{{showQuickMark || showPetitionMini}}" class="action-bar">
    <button wx:if="{{showQuickMark}}" class="btn-mark" size="mini" catchtap="onMarkTap">
      {{game._marked ? '已标记' : '标记玩过'}}
    </button>
    <button
      wx:if="{{showPetitionMini}}"
      class="btn-pet"
      size="mini"
      catchtap="onPetitionTap"
      disabled="{{game._petitionDone}}"
    >
      {{game._petitionDone ? '已请愿' : '我盼它回归'}}
    </button>
  </view>
  <view
    wx:if="{{showRemove}}"
    class="remove"
    catchtap="onRemoveTap"
  >取消收藏</view>
</view>
