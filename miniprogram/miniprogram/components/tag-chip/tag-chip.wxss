.chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  min-width: 72rpx;
  padding: 10rpx 24rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: #8b5a2b;
  border: 2rpx solid #d2b48c;
  border-radius: 12rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.chip--on {
  background: #8b5a2b;
  color: #ffffff;
  border-color: #8b5a2b;
}
